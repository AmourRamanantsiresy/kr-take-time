# Rendered from configs/opennds.conf.tmpl — do not edit by hand.
# Installed to /etc/config/opennds — since OpenNDS 10.1 the config is
# UCI format at this path on ALL distros (the legacy
# /etc/opennds/opennds.conf is ignored).

config opennds
	option enabled '1'
	option debuglevel '1'

	option gatewayinterface '${LAN_IF}'
	option gatewayname '${GATEWAY_NAME}'
	option gatewayport '2050'
	option maxclients '250'

	# FAS: our NestJS backend, reached through Caddy at /fas.
	# fasremoteip/fasremotefqdn are deliberately NOT set: opennds then
	# defaults the FAS to the gateway address and treats it as LOCAL,
	# whitelisting fasport on the INPUT path for preauthenticated
	# clients. Setting fasremotefqdn makes opennds treat the FAS as
	# remote and only whitelist it on the FORWARD path — clients then
	# get connection-refused. Clients are redirected by gateway IP, so
	# the captive flow has no DNS dependency at all.
	# Port 80 is reserved by opennds for its own redirects, hence
	# FAS_PORT (Caddy serves the portal on both :80 and :FAS_PORT).
	# fas_secure_enabled 1 → the query string arrives base64 encoded and
	# carries the hashed client id (hid). Authorization itself is done by
	# the backend via `ndsctl auth`, never by returning tokens to clients.
	option fasport '${FAS_PORT}'
	option faspath '/fas'
	option faskey '${FAS_KEY}'
	option fas_secure_enabled '1'

	# Time enforcement: no global session timeout; the backend passes an
	# explicit per-client timeout with every `ndsctl auth` call, computed
	# from the account balance. OpenNDS auto-deauths when it elapses.
	option sessiontimeout '0'
	option preauthidletimeout '10'
	option authidletimeout '120'
	option checkinterval '15'
