# Rendered from configs/opennds.conf.tmpl — do not edit by hand.
# OpenNDS captive portal — key/value config (Debian, non-UCI format).
# Option names are parsed case-insensitively by opennds.

GatewayInterface ${LAN_IF}
GatewayName ${GATEWAY_NAME}
GatewayPort 2050
MaxClients 250

# FAS: our NestJS backend, reached through Caddy on port 80 at /fas.
# fas_secure_enabled 1 → the query string arrives base64 encoded and
# carries the hashed client id (hid). Authorization itself is done by
# the backend via `ndsctl auth`, never by returning tokens to clients.
FasPort 80
FasPath /fas
FasRemoteFQDN ${PORTAL_HOST}
FasKey ${FAS_KEY}
fas_secure_enabled 1

# Time enforcement:
#   SessionTimeout 0  → no global default; the backend passes an explicit
#   per-client session timeout with every `ndsctl auth` call, computed
#   from the account balance. OpenNDS auto-deauths when it elapses.
SessionTimeout 0
PreauthIdleTimeout 10
AuthIdleTimeout 120
CheckInterval 15

DebugLevel 1
