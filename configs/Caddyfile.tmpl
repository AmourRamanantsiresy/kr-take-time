# Rendered from configs/Caddyfile.tmpl — do not edit by hand.
# Captive-portal clients must reach the portal over plain HTTP (no public
# CA can issue for a LAN-only name, and self-signed certs break captive
# browsers). Explicit http:// prefixes disable Caddy's automatic-HTTPS
# redirect for these hosts.
#
# The same site is served on two ports:
#   :${FAS_PORT} — the captive-portal loop. OpenNDS reserves :80 for its
#                  own redirects, so unauthenticated clients do the whole
#                  FAS → login → connect flow on this port.
#   :80          — normal access for already-authenticated users/admins.

(cybera_site) {
	encode gzip

	handle /api/* {
		reverse_proxy 127.0.0.1:${BACKEND_PORT}
	}

	handle /fas* {
		reverse_proxy 127.0.0.1:${BACKEND_PORT}
	}

	handle {
		root * ${APP_DIR}/frontend/dist
		try_files {path} /index.html
		file_server
	}
}

# Host-agnostic on purpose: captive-portal clients reach us by
# PORTAL_HOST, by raw IP, or by whatever Host their popup browser sends.
# A host-matched site would answer unknown Hosts with Caddy's bare empty
# 200 — which renders as a blank page.
http://:80 {
	import cybera_site
}

http://:${FAS_PORT} {
	import cybera_site
}
