# Rendered from configs/sudoers-cybera.tmpl — do not edit by hand.
# Installed to /etc/sudoers.d/cybera (0440).
# The backend/session-manager run as the unprivileged "cybera" user; the
# ONLY privileged operations they may perform are ndsctl (authorize/
# deauthorize clients) and conntrack (kill a kicked client's live flows).
cybera ALL=(root) NOPASSWD: ${NDSCTL_PATH}, ${CONNTRACK_PATH}
