# Rendered from configs/interfaces.tmpl — do not edit by hand.
# Installed to /etc/network/interfaces.d/cybera
# LAN (faces the AP/bridge router) is the static gateway. The WAN stanza
# is appended from interfaces-wan.tmpl only when the WAN is wired; a
# Wi-Fi WAN stays under NetworkManager, which handles the association.

auto ${LAN_IF}
allow-hotplug ${LAN_IF}
iface ${LAN_IF} inet static
    address ${LAN_GATEWAY_IP}
    netmask ${LAN_NETMASK}
