# ── Network interfaces ────────────────────────────────────────────────
# Run `ip -o link` to list interfaces. NEVER guess:
#   WAN_IF = the interface facing Starlink. Either a wired one (USB
#            adapter enx… / onboard enp…) or, if the box joins the
#            Starlink Wi-Fi, the wireless interface (wlp…). A Wi-Fi WAN
#            stays managed by NetworkManager — join the network once in
#            the desktop UI before running install.sh.
#   LAN_IF = the interface facing the router/users (wired only)
WAN_IF=wlp2s0
LAN_IF=enx00e04c680001

# ── LAN addressing ────────────────────────────────────────────────────
LAN_SUBNET=192.168.50.0/24
LAN_GATEWAY_IP=192.168.50.1
# dnsmasq dhcp-range: start,end,netmask,lease
DHCP_RANGE=192.168.50.10,192.168.50.250,255.255.255.0,12h

# ── Captive portal ────────────────────────────────────────────────────
GATEWAY_NAME=CyberCafe
# Hostname the portal is served on inside the LAN (dnsmasq resolves it
# to LAN_GATEWAY_IP). Keep it a plain local name.
PORTAL_HOST=portal.cafe
# Shared secret between OpenNDS and the backend FAS. Generate with:
#   openssl rand -hex 32
FAS_KEY=change-me-openssl-rand-hex-32
# LAN port Caddy serves the captive-portal loop on. Must NOT be 80:
# OpenNDS reserves port 80 for its own redirects when the FAS is on the
# gateway's IP. Authenticated users still reach the portal on :80.
FAS_PORT=8080

# ── Database ──────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=cybera
DB_USER=cybera
DB_PASS=change-me-db-password

# ── Backend ───────────────────────────────────────────────────────────
BACKEND_PORT=3000
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# ── Seed admin account ────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=change-me-admin-password
# Numbered walk-in client accounts (1..N) seeded for password-less login
CLIENT_COUNT=100

# ── Session manager ───────────────────────────────────────────────────
# Reconciler tick in seconds
SESSION_TICK_SECONDS=15
# Hard cap for a single ndsctl session (seconds); balance is still the
# source of truth, the reconciler re-checks every tick.
MAX_SESSION_SECONDS=86400
